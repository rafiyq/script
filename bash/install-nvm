#!/usr/bin/env bash

set -euo pipefail

log() { echo -e "[\033[0;32mINFO\033[0m] $1"; }
error() { echo -e "[\033[0;31mERROR\033[0m] $1" >&2; }

# Robust check for NVM
if [ -d "$HOME/.nvm" ] || command -v nvm &> /dev/null || [ -n "${NVM_DIR:-}" ]; then
  log "NVM already installed. Skipping..."
else
  log "Installing NVM..."
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/refs/heads/master/install.sh | bash
fi

export NVM_DIR="$HOME/.nvm"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  source "$NVM_DIR/nvm.sh"
  log "nvm $(nvm --version) installed successfully."
else
  error "NVM installation failed."
  exit 1
fi
