#!/usr/bin/env bash

set -euo pipefail

# Get the directory where the script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Function to log messages
log() {
  echo -e "[\033[0;32mINFO\033[0m] $1"
}

# Function to check for required tools
check_deps() {
  local deps=("curl" "bash" "sh")
  for dep in "${deps[@]}"; do
    if ! command -v "$dep" &> /dev/null; then
      echo "Error: $dep is not installed." >&2
      exit 1
    fi
  done
}

# Robust checks for current status
is_nvm_installed() { [ -d "$HOME/.nvm" ] || command -v nvm &> /dev/null || [ -n "${NVM_DIR:-}" ]; }
is_sdkman_installed() { [ -d "$HOME/.sdkman" ] || command -v sdk &> /dev/null || [ -n "${SDKMAN_DIR:-}" ]; }
is_rust_installed() { command -v rustup &> /dev/null || [ -d "$HOME/.rustup" ]; }

# Source profile for the current shell
source_profile() {
  local shell_type
  shell_type=$(basename "$SHELL")
  local profile=""
  
  case $shell_type in
    bash)
      if [ -f "$HOME/.bashrc" ]; then profile="$HOME/.bashrc";
      elif [ -f "$HOME/.bash_profile" ]; then profile="$HOME/.bash_profile"; fi
      ;;
    zsh)
      if [ -f "$HOME/.zshrc" ]; then profile="$HOME/.zshrc"; fi
      ;;
    *)
      log "Unknown shell: $shell_type. Please manually source your profile."
      return
      ;;
  esac
  
  if [ -n "$profile" ]; then
    log "Sourcing $profile..."
    source "$profile"
  fi
}

# Menu for selecting packages
select_packages() {
  echo "Select packages to install (separate multiple choices with spaces, e.g., '1 3'):"
  
  local nvm_status="[ ]"
  local sdkman_status="[ ]"
  local rust_status="[ ]"
  
  is_nvm_installed && nvm_status="[\033[0;32mINSTALLED\033[0m]"
  is_sdkman_installed && sdkman_status="[\033[0;32mINSTALLED\033[0m]"
  is_rust_installed && rust_status="[\033[0;32mINSTALLED\033[0m]"

  echo -e "1) NVM     $nvm_status"
  echo -e "2) SDKMAN  $sdkman_status"
  echo -e "3) Rustup  $rust_status"
  echo "4) All"
  echo "5) Exit"
  
  read -r -p "Your choice: " choices
  
  for choice in $choices; do
    case $choice in
      1) "$SCRIPT_DIR/install-nvm" ;;
      2) "$SCRIPT_DIR/install-sdkman" ;;
      3) "$SCRIPT_DIR/install-rust" ;;
      4) "$SCRIPT_DIR/install-nvm"; "$SCRIPT_DIR/install-sdkman"; "$SCRIPT_DIR/install-rust" ;;
      5) log "Exiting."; exit 0 ;;
      *) echo "Invalid choice: $choice" ;;
    esac
  done
}

# Main execution
main() {
  check_deps
  select_packages
  
  source_profile
  
  log "Environment setup check complete!"
  log "Note: To apply changes to your current shell, please run: source <your-profile>"
}

main "$@"
