#!/usr/bin/env bash

set -euo pipefail

# Configuration
INSTALL_DIR="/opt"
BIN_LINK_PATH="/usr/local/bin/nvim"
NVIM_RELEASE_URL="https://github.com/neovim/neovim/releases/latest/download"

# Function to log messages
log() {
  echo -e "[\033[0;32mINFO\033[0m] $1"
}

# Function to log errors
error() {
  echo -e "[\033[0;31mERROR\033[0m] $1" >&2
  exit 1
}

# Function to check for required dependencies
check_dependencies() {
  local deps=("curl" "tar" "uname" "sed" "tr" "sudo" "mktemp")
  for dep in "${deps[@]}"; do
    if ! command -v "$dep" &> /dev/null; then
      error "Required tool '$dep' is not installed."
    fi
  done
}

# Function to detect OS and Architecture
detect_platform() {
  local os_name
  os_name=$(uname -s | tr '[:upper:]' '[:lower:]' | sed 's/darwin/macos/')
  
  local arch_name
  arch_name=$(uname -m | sed 's/aarch64/arm64/')
  
  if [[ "$os_name" != "linux" && "$os_name" != "macos" ]]; then
    error "Unsupported OS: $os_name"
  fi
  
  if [[ "$arch_name" != "x86_64" && "$arch_name" != "arm64" ]]; then
    error "Unsupported architecture: $arch_name"
  fi
  
  echo "nvim-${os_name}-${arch_name}"
}

# Function to install Neovim
install_nvim() {
  local nvim_pkg_name="$1"
  local nvim_tarball="${nvim_pkg_name}.tar.gz"
  local temp_dir
  temp_dir=$(mktemp -d)
  
  # Ensure cleanup on exit
  trap 'rm -rf "$temp_dir"' EXIT
  
  log "Downloading Neovim: ${nvim_pkg_name}..."
  if ! curl -L -o "${temp_dir}/${nvim_tarball}" "${NVIM_RELEASE_URL}/${nvim_tarball}"; then
    error "Failed to download Neovim from ${NVIM_RELEASE_URL}/${nvim_tarball}"
  fi
  
  log "Extracting Neovim to ${INSTALL_DIR}..."
  sudo rm -rf "${INSTALL_DIR}/${nvim_pkg_name}"
  if ! sudo tar -C "${INSTALL_DIR}" -xzf "${temp_dir}/${nvim_tarball}"; then
    error "Failed to extract Neovim to ${INSTALL_DIR}"
  fi
  
  log "Creating symbolic link at ${BIN_LINK_PATH}..."
  sudo ln -sf "${INSTALL_DIR}/${nvim_pkg_name}/bin/nvim" "${BIN_LINK_PATH}"
}

# Main execution
main() {
  check_dependencies
  
  local nvim_pkg
  nvim_pkg=$(detect_platform)
  
  install_nvim "$nvim_pkg"
  
  log "Neovim installation complete."
  log "Verifying installation:"
  if command -v nvim &> /dev/null; then
    nvim --version | head -n 1
  else
    error "Neovim binary not found in PATH."
  fi
}

main "$@"
