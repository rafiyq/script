#!/usr/bin/env bash

set -euo pipefail

# Configuration
INSTALL_BASE="/opt"
BIN_DIR="/usr/local/bin"
NVIM_RELEASE_URL="https://github.com/neovim/neovim/releases/latest/download"

# Logging functions
log() { echo -e "[\033[0;32mINFO\033[0m] $1"; }
error() { echo -e "[\033[0;31mERROR\033[0m] $1" >&2; exit 1; }

# Check dependencies
for dep in curl tar uname sed tr sudo mktemp; do
  if ! command -v "$dep" &>/dev/null; then
    error "Required tool '$dep' is not installed."
  fi
done

# Detect Checksum Tool
if command -v sha256sum &>/dev/null; then
  CHECK_CMD="sha256sum --check --status"
elif command -v shasum &>/dev/null; then
  CHECK_CMD="shasum -a 256 --check --status"
else
  log "Warning: Neither 'sha256sum' nor 'shasum' found. Skipping checksum verification."
  CHECK_CMD=""
fi

# Detect OS and Architecture
os_name=$(uname -s | tr '[:upper:]' '[:lower:]' | sed 's/darwin/macos/')
arch_name=$(uname -m | sed 's/aarch64/arm64/')

if [[ "$os_name" != "linux" && "$os_name" != "macos" ]]; then
  error "Unsupported OS: $os_name"
fi

if [[ "$arch_name" != "x86_64" && "$arch_name" != "arm64" ]]; then
  error "Unsupported architecture: $arch_name"
fi

nvim_pkg="nvim-${os_name}-${arch_name}"
nvim_tarball="${nvim_pkg}.tar.gz"
checksum_file="shasum.txt"

# Download and Verify
temp_dir=$(mktemp -d)
trap 'rm -rf "$temp_dir"' EXIT

log "Downloading Neovim: ${nvim_pkg}..."
if ! curl -L -o "${temp_dir}/${nvim_tarball}" "${NVIM_RELEASE_URL}/${nvim_tarball}"; then
  error "Failed to download Neovim from ${NVIM_RELEASE_URL}/${nvim_tarball}"
fi

if [[ -n "$CHECK_CMD" ]]; then
  log "Verifying checksum..."
  # Use -f to fail if the file is not found (404)
  if curl -L -f -s -o "${temp_dir}/${checksum_file}" "${NVIM_RELEASE_URL}/${checksum_file}"; then
    if ! (cd "$temp_dir" && grep "${nvim_tarball}" "${checksum_file}" | $CHECK_CMD); then
      error "Checksum verification failed! The downloaded file may be corrupted."
    fi
    log "Checksum verified."
  else
    log "Warning: Could not download checksum file. Skipping verification."
  fi
fi

# Extract and Install
log "Extracting Neovim to ${INSTALL_BASE}..."
sudo rm -rf "${INSTALL_BASE}/${nvim_pkg}"
if ! sudo tar -C "${INSTALL_BASE}" -xzf "${temp_dir}/${nvim_tarball}"; then
  error "Failed to extract Neovim to ${INSTALL_BASE}"
fi

log "Creating symbolic link at ${BIN_DIR}/nvim..."
sudo ln -sf "${INSTALL_BASE}/${nvim_pkg}/bin/nvim" "${BIN_DIR}/nvim"

if command -v nvim &>/dev/null; then
  log "$(nvim --version | head -n 1) installed successfully."
else
  error "Neovim installation failed. Binary not found in PATH."
fi
